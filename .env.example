APP_NAME=NestyAI
APP_VERSION=0.1.0
APP_ENV=production

GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

REQUEST_TIMEOUT_SECONDS=30
ENABLE_INPUT_GUARD=true
ENABLE_OUTPUT_GUARD=true

# Optional if you want to enable NVIDIA OpenAI-compatible endpoint routing
NVIDIA_BASE_URL=

# Optional for Phase 3 tool foundations (non-AI free APIs)

# Weather + geocoding
WEATHER_PROVIDER_PRIMARY=open-meteo
WEATHER_PROVIDER_FALLBACK=open-meteo
WEATHER_API_PRIMARY=https://api.open-meteo.com/v1/forecast
WEATHER_API_FALLBACK=https://api.open-meteo.com/v1/forecast
GEOCODING_PROVIDER_PRIMARY=nominatim
GEOCODING_PROVIDER_FALLBACK=open-meteo-geocoding
GEOCODING_API_PRIMARY=https://nominatim.openstreetmap.org/search
GEOCODING_API_FALLBACK=https://geocoding-api.open-meteo.com/v1/search

# Exchange
EXCHANGE_PROVIDER_PRIMARY=frankfurter
EXCHANGE_PROVIDER_FALLBACK=exchangerate-api-open
EXCHANGE_API_PRIMARY=https://api.frankfurter.app/latest
EXCHANGE_API_FALLBACK=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# Tech realtime
TECH_REALTIME_PROVIDER_PRIMARY=hacker-news-firebase
TECH_REALTIME_PROVIDER_FALLBACK=github-events
TECH_REALTIME_API_PRIMARY=https://hacker-news.firebaseio.com/v0
TECH_REALTIME_API_FALLBACK=https://api.github.com/events

# Crypto
CRYPTO_PROVIDER_PRIMARY=coingecko
CRYPTO_PROVIDER_FALLBACK=coingecko
CRYPTO_API_PRIMARY=https://api.coingecko.com/api/v3/simple/price
CRYPTO_API_FALLBACK=https://api.coingecko.com/api/v3/coins/markets
CRYPTO_API_KEY=

# Earthquake
EARTHQUAKE_PROVIDER_PRIMARY=usgs-geojson
EARTHQUAKE_PROVIDER_FALLBACK=usgs-geojson
EARTHQUAKE_API_PRIMARY=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
EARTHQUAKE_API_FALLBACK=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson

# Air quality
AIR_QUALITY_PROVIDER_PRIMARY=openaq
AIR_QUALITY_PROVIDER_FALLBACK=openaq
AIR_QUALITY_API_PRIMARY=https://api.openaq.org/v3/locations
AIR_QUALITY_API_FALLBACK=https://api.openaq.org/v3/sensors
AIR_QUALITY_API_KEY=

# Dev metadata
DEV_METADATA_PROVIDER_PRIMARY=github-api
DEV_METADATA_PROVIDER_FALLBACK=registries
DEV_METADATA_API_PRIMARY=https://api.github.com
DEV_METADATA_API_FALLBACK=https://registry.npmjs.org
DEV_METADATA_API_FALLBACK_2=https://pypi.org/pypi
GITHUB_API_TOKEN=

# Legacy compatibility keys
WEATHER_PROVIDER_API_KEY=

# Phase 4: auth, rate limit, usage tracking
NESTY_DB_PATH=data/nesty.db
NESTY_API_KEY_HASH_SECRET=
REQUIRE_API_KEY=true
PUBLIC_HEALTH=false
PUBLIC_MODELS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30
SAFE_DEBUG_AUTH=false

# Phase 5.2: deployment hardening
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=https://your-tunnel-domain.example
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Nesty-API-Key
CORS_ALLOW_CREDENTIALS=false
TRUSTED_HOSTS=your-tunnel-domain.example
MAX_REQUEST_BODY_BYTES=1048576
SECURITY_HEADERS_ENABLED=true
ENABLE_HSTS=true

# Cloudflare Tunnel token
CLOUDFLARE_TUNNEL_TOKEN=

# Docker Compose sidecar mode
CLOUDFLARE_TUNNEL_ENABLED=false

# Pterodactyl / container-panel cloudflared runtime
TUNNEL_AUTO_INSTALL_CLOUDFLARED=1
CLOUDFLARED_BIN_PATH=/home/container/.cloudflared/bin/cloudflared
TUNNEL_ENABLED=1
CLOUDFLARED_LOG_PATH=./cloudflare/cloudflared.log
CLOUDFLARED_PID_PATH=./cloudflare/cloudflared.pid

# Phase 6: conversation session memory foundation
CONVERSATION_HISTORY_ENABLED=true
CONVERSATION_HISTORY_MAX_MESSAGES=20
CONVERSATION_HISTORY_MAX_CHARS=12000

# Phase 6.1: conversation summarization and history compression
CONVERSATION_SUMMARY_ENABLED=true
CONVERSATION_SUMMARY_TRIGGER_MESSAGES=30
CONVERSATION_SUMMARY_KEEP_RECENT_MESSAGES=12
CONVERSATION_SUMMARY_MAX_CHARS=4000
CONVERSATION_SUMMARY_MODEL=nesty-flash-1.0

# Phase 7.0a: Nesty Pro optional multi-model orchestration
NESTY_PRO_ORCHESTRATION_ENABLED=true
NESTY_PRO_ORCHESTRATION_MAX_INTERNAL_CALLS=4
NESTY_PRO_ORCHESTRATION_DEBUG=false
NESTY_PRO_ORCHESTRATION_COMPLEXITY_MIN_SCORE=2
NESTY_PRO_ORCHESTRATION_SIMPLE_MAX_CHARS=220
NESTY_PRO_ORCHESTRATION_MAX_CONTEXT_CHARS=12000
NESTY_PRO_ORCHESTRATION_ROLE_TIMEOUT_SECONDS=30
NESTY_PRO_ORCHESTRATION_INCLUDE_ROLE_LATENCY=true

# Phase 7.0c: internal runtime model config API (server-to-server only)
INTERNAL_ADMIN_ENABLED=false
NESTY_INTERNAL_ADMIN_TOKEN=

# Optional ephemeral API key generated at Gateway startup for Nesty Console.
# Useful for Pterodactyl/container-panel deployments where scripts cannot be run interactively.
NESTY_EPHEMERAL_CONSOLE_KEY_ENABLED=false
NESTY_EPHEMERAL_CONSOLE_KEY_NAME=nesty-console-ephemeral
NESTY_EPHEMERAL_CONSOLE_KEY_ENV=prod
NESTY_EPHEMERAL_CONSOLE_KEY_DAILY_LIMIT=10000
NESTY_EPHEMERAL_CONSOLE_KEY_MONTHLY_LIMIT=
NESTY_EPHEMERAL_CONSOLE_KEY_MODELS=nesty-flash-1.0,nesty-combined-1.0,nesty-pro-1.0
NESTY_EPHEMERAL_CONSOLE_KEY_PREFIX=nsk_console

# Phase 7.1: embedding provider abstraction foundation
EMBEDDINGS_ENABLED=false
EMBEDDINGS_PROVIDER=openrouter
EMBEDDINGS_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDINGS_DIMENSIONS=
EMBEDDINGS_TIMEOUT_SECONDS=30
EMBEDDINGS_MAX_INPUT_CHARS=8000
EMBEDDINGS_STORE_MESSAGE_EMBEDDINGS=false
EMBEDDINGS_BACKFILL_BATCH_SIZE=50

# Phase 7.2: semantic recall (optional, local cosine similarity over stored embeddings)
SEMANTIC_RECALL_ENABLED=false
SEMANTIC_RECALL_TOP_K=5
SEMANTIC_RECALL_MIN_SCORE=0.72
SEMANTIC_RECALL_MAX_CONTEXT_CHARS=4000
SEMANTIC_RECALL_SCOPE=conversation
SEMANTIC_RECALL_INCLUDE_ROLES=user,assistant
SEMANTIC_RECALL_EXCLUDE_CURRENT_CONVERSATION_RECENT=true
SEMANTIC_RECALL_CANDIDATE_LIMIT=500
SEMANTIC_RECALL_PINNED_BOOST=0.08
SEMANTIC_RECALL_DEDUP_SIMILARITY=0.96
SEMANTIC_RECALL_MAX_PER_CONVERSATION=3
SEMANTIC_RECALL_EXCLUDE_MEMORY_EXCLUDED=true

# Phase 8.0: provider diagnostics and health checks
DIAGNOSTICS_ENABLED=true
DIAGNOSTICS_DEFAULT_TIMEOUT_SECONDS=20
DIAGNOSTICS_TEST_MAX_TOKENS=16
DIAGNOSTICS_SAVE_RESULTS=true
DIAGNOSTICS_OUTPUT_PREVIEW_CHARS=80

# Phase 8.1: optional health-aware provider routing
PROVIDER_HEALTH_AWARE_ROUTING=false
PROVIDER_HEALTH_STRICT_MODE=false
PROVIDER_HEALTH_TTL_SECONDS=900
PROVIDER_HEALTH_FAILURE_THRESHOLD=2
PROVIDER_HEALTH_SKIP_STATUSES=failed,unavailable,timeout
PROVIDER_HEALTH_ALLOW_STALE_AFTER_SECONDS=3600

# Phase 8.3: provider reliability scoring
PROVIDER_RELIABILITY_SCORING_ENABLED=true
PROVIDER_RELIABILITY_WINDOW_CHECKS=20
PROVIDER_RELIABILITY_MIN_CHECKS=3
PROVIDER_RELIABILITY_RECENCY_WEIGHT=0.65
PROVIDER_RELIABILITY_LATENCY_WEIGHT=0.20
PROVIDER_RELIABILITY_STABILITY_WEIGHT=0.15
PROVIDER_RELIABILITY_OK_SCORE=1.0
PROVIDER_RELIABILITY_FAILED_SCORE=0.0
PROVIDER_RELIABILITY_UNAVAILABLE_SCORE=0.0
PROVIDER_RELIABILITY_TIMEOUT_SCORE=0.0
PROVIDER_RELIABILITY_SKIPPED_SCORE=0.4
