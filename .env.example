APP_NAME=NestyAI
APP_VERSION=0.1.0
APP_ENV=development

GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

REQUEST_TIMEOUT_SECONDS=30
ENABLE_INPUT_GUARD=true
ENABLE_OUTPUT_GUARD=true

# Optional if you want to enable NVIDIA OpenAI-compatible endpoint routing
NVIDIA_BASE_URL=

# Optional for Phase 3 tool foundations
WEATHER_PROVIDER_API_KEY=
EXCHANGE_RATE_API_KEY=

# Phase 4: auth, rate limit, usage tracking
NESTY_DB_PATH=data/nesty.db
NESTY_API_KEY_HASH_SECRET=
REQUIRE_API_KEY=false
PUBLIC_HEALTH=true
PUBLIC_MODELS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SAFE_DEBUG_AUTH=false
